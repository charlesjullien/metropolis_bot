TELEGRAM_BOT_TOKEN="..."

# Timezone for daily notifications (IANA name)
BOT_TIMEZONE=Europe/Paris

# Heure d'envoi : par utilisateur en base (setup ou /heure_notif), pas via .env.

# Optional: Île-de-France Mobilités PRIM Navitia token
# If set, PRIM is used to query disruptions.
IDFM_PRIM_API_KEY="..."

# SQLite DB path (relative or absolute)
DB_PATH=bot.db

# Telegram numeric user id allowed to run /purge_db YES (wipes entire DB). Leave empty to disable.
BOT_ADMIN_TELEGRAM_ID=

# If set to 0, the bot won't run its internal notification scheduler
# (useful when PythonAnywhere cron calls /check_for_notifications).
ENABLE_INTERNAL_NOTIF_SCHEDULER=0

# Secret pour le webhook Telegram (HTTPS). Même valeur que secret_token dans setWebhook.
# Telegram envoie l’en-tête X-Telegram-Bot-Api-Secret-Token ; sans ce secret, /telegram_webhook répond 503.
# Génère une chaîne longue aléatoire (ex. openssl rand -hex 32).
TELEGRAM_WEBHOOK_SECRET=e503f83bba20744ca2faee803985373be41bff2958934d76401cdcdb5d62fdf7

# Événement historique du jour (API « Ce jour-là », Wikipédia / Wikimedia).
# Langue (sous-domaine wiki, ex. fr, en).
WIKIPEDIA_ONTHISDAY_LANG=fr
# Fortement recommandé : URL https ou email de contact pour le User-Agent (évite les 403).
# Ex. https://t.me/ton_bot ou ton@email.com
WIKIPEDIA_HTTP_CONTACT=bonjourcestmoi@gmail.com

# Départs transports:
# 1 = autorise le fallback planning si le realtime est indisponible
# 0 = strict realtime uniquement
ALLOW_PLANNING_FALLBACK=1

# Nombre de retries des appels realtime (en plus du 1er essai), borne 0..5
REALTIME_DEPARTURES_RETRIES=2